{
  "name": "luminacms",
  "version": "1.0.0",
  "private": true,
  "description": "LuminaCMS — 極美感個人離線內容管理系統",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "node prisma/seed.cjs",
    "electron:dev": "electron electron/main.js",
    "electron:build": "next build && node scripts/copy-standalone.js && electron-builder",
    "electron:build:win": "next build && node scripts/copy-standalone.js && electron-builder --win",
    "electron:build:mac": "next build && node scripts/copy-standalone.js && electron-builder --mac",
    "electron:build:linux": "next build && node scripts/copy-standalone.js && electron-builder --linux"
  },
  "dependencies": {
    "@craftjs/core": "^0.2.12",
    "@craftjs/layers": "^0.2.7",
    "@prisma/client": "^7.5.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "lenis": "^1.3.19",
    "motion": "^12.38.0",
    "next": "16.1.7",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
